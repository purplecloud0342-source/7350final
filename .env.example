# GEMINI_API_KEY: Required for Gemini AI API calls.
# Add your Gemini API key below for local development.
# NEVER commit your real API key into source control.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: add DeepSeek API key if you want DeepSeek proxy support.
DEEPSEEK_API_KEY=

# Optional: add Comfly relay key for https://ai.comfly.chat/v1/chat/completions
COMFLY_API_KEY=
# APP_URL is optional and used for deployment metadata if needed.
APP_URL=

